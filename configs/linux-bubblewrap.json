{
  "version": "0.6.0-alpha",
  "containerId": "enclawed-bubblewrap-linux",
  "containment": "bubblewrap",
  "platform": "linux",
  "process": {
    "commandLine": "/usr/bin/node /opt/enclawed/enclawed.mjs secretary"
  },
  "filesystem": {
    "readonlyPaths": [
      "/opt/enclawed",
      "/usr",
      "/lib",
      "/lib64",
      "/etc/ssl/certs"
    ],
    "readwritePaths": [
      "/var/lib/enclawed",
      "/tmp"
    ]
  },
  "network": {
    "defaultPolicy": "block",
    "enforcementMode": "firewall",
    "allowedHosts": [
      "api.anthropic.com",
      "127.0.0.1"
    ]
  }
}
